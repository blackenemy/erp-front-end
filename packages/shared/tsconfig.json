{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "paths": {
      "@repo/shared/*": ["./src/*"]
    },
    "types": ["jest", "@testing-library/jest-dom"]
  },
  "include": ["global.d.ts", "src/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "**/*.test.*"]
}
